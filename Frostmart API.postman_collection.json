        {
          "name": "ADMIN SIGNIN",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function(){\r",
                  "    pm.response.to.have.status(200)\r",
                  "})\r",
                  "\r",
                  "const setCookieHeaders = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie');\r",
                  "const accessCookie = setCookieHeaders.find(h => h.value.startsWith('access_token='));\r",
                  "\r",
                  "pm.test(\"access_token cookie exists\", function(){\r",
                  "    pm.expect(accessCookie).to.exist;\r",
                  "})\r",
                  "\r",
                  "if (accessCookie) {\r",
                  "    const token = accessCookie.value.match(/access_token=([^;]+)/)?.[1];\r",
                  "    if (token) {\r",
                  "        pm.environment.set('access_token', token);\r",
                  "    }\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"{{admin_email}}\",\r\n  \"password\": \"{{admin_password}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{url}}/auth/local/signin",
              "host": [
                "{{url}}"
              ],
              "path": [
                "auth",
