{
  "info": {
    "_postman_id": "17a493ba-e12b-4c13-9156-b4ccbfd0a8a0",
    "name": "Local Auth Express API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "33041331"
  },
  "item": [
    {
      "name": "Signup",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Signup success\", () => {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const res = pm.response.json();",
              "pm.expect(res).to.have.property(\"user\");",
              "",
              "pm.environment.set(\"user_id\", res.user.id);",
              "pm.environment.set(\"user_email\", res.user.email);",
              "pm.environment.set(\"user_role\", res.user.role);",
              "",
              "const cookies = pm.cookies.toObject();",
              "if (cookies.access_token) pm.environment.set(\"access_token\", cookies.access_token);",
              "if (cookies.refresh_token) pm.environment.set(\"refresh_token\", cookies.refresh_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{test_name}}\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/auth/local/signup",
          "host": [
            "{{url}}"
          ],
          "path": [
            "auth",
            "local",
            "signup"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Signin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Signin success\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const res = pm.response.json();",
              "if (res.user) {",
              "  pm.environment.set(\"user_id\", res.user.id);",
              "  pm.environment.set(\"user_email\", res.user.email);",
              "  pm.environment.set(\"user_role\", res.user.role);",
              "}",
              "",
              "const cookies = pm.cookies.toObject();",
              "if (cookies.access_token) pm.environment.set(\"access_token\", cookies.access_token);",
              "if (cookies.refresh_token) pm.environment.set(\"refresh_token\", cookies.refresh_token);",
              "",
              "if (res.accessToken) pm.environment.set(\"access_token\", res.accessToken);",
              "if (res.refreshToken) pm.environment.set(\"refresh_token\", res.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/auth/local/signin",
          "host": [
            "{{url}}"
          ],
          "path": [
            "auth",
            "local",
            "signin"
          ]
        }
      },
      "response": []
    },
    {
      "name": "User data",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Get current user\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const res = pm.response.json();",
              "pm.expect(res).to.have.property(\"id\");",
              "pm.expect(res).to.have.property(\"name\");",
              "pm.expect(res).to.have.property(\"email\");",
              "pm.expect(res).to.have.property(\"role\");",
              "",
              "pm.environment.set(\"user_id\", res.id);",
              "pm.environment.set(\"user_email\", res.email);",
              "pm.environment.set(\"user_role\", res.role);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{url}}/auth/user/me",
          "host": [
            "{{url}}"
          ],
          "path": [
            "auth",
            "user",
            "me"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update user data",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Update success\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const res = pm.response.json();",
              "pm.expect(res.email).to.eql(pm.environment.get(\"updated_email\"));",
              "pm.environment.set(\"user_email\", res.email);"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{updated_name}}\",\n  \"email\": \"{{updated_email}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{url}}/auth/user/me",
          "host": [
            "{{url}}"
          ],
          "path": [
            "auth",
            "user",
            "me"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Refresh token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Refresh success\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const res = pm.response.json();",
              "if (res.accessToken) pm.environment.set(\"access_token\", res.accessToken);",
              "if (res.refreshToken) pm.environment.set(\"refresh_token\", res.refreshToken);",
              "",
              "const cookies = pm.cookies.toObject();",
              "if (cookies.access_token) pm.environment.set(\"access_token\", cookies.access_token);",
              "if (cookies.refresh_token) pm.environment.set(\"refresh_token\", cookies.refresh_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{url}}/auth/refresh-token",
          "host": [
            "{{url}}"
          ],
          "path": [
            "auth",
            "refresh-token"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Signout",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Logout success\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.environment.unset(\"access_token\");",
              "pm.environment.unset(\"refresh_token\");"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{url}}/auth/remove-session",
          "host": [
            "{{url}}"
          ],
          "path": [
            "auth",
            "remove-session"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get(\"test_name\")) pm.environment.set(\"test_name\", \"Postman User\");",
          "if (!pm.environment.get(\"test_password\")) pm.environment.set(\"test_password\", \"123456\");",
          "if (!pm.environment.get(\"test_email\")) pm.environment.set(\"test_email\", `user_${Date.now()}@example.com`);",
          "if (!pm.environment.get(\"updated_name\")) pm.environment.set(\"updated_name\", \"Postman User Updated\");",
          "if (!pm.environment.get(\"updated_email\")) pm.environment.set(\"updated_email\", `updated_${Date.now()}@example.com`);",
          "",
          "if (pm.environment.get(\"access_token\")) {",
          "  pm.request.headers.upsert({ key: \"Authorization\", value: \"Bearer \" + pm.environment.get(\"access_token\") });",
          "}",
          "",
          "if (pm.environment.get(\"refresh_token\")) {",
          "  pm.request.headers.upsert({ key: \"x-refresh-token\", value: pm.environment.get(\"refresh_token\") });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "url",
      "value": "http://localhost:5000/api"
    }
  ]
}
